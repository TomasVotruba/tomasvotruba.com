            "keep": false
        },
        {
            "package": "staabm/phpstan-dba",
            "description": "PHPStan based SQL static analysis and type inference for the database access layer.",
            "url": "https://github.com/staabm/phpstan-dba",
            "keep": false
        },
        {
            "package": "shipmonk/phpstan-rules",
            "description": "Various extra strict PHPStan rules we found useful at ShipMonk.",
            "url": "https://github.com/shipmonk-rnd/phpstan-rules",
            "keep": false
        },
        {
            "package": "voku/phpstan-rules",
            "description": "Provides additional rules for phpstan/phpstan.",
